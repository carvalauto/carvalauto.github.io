{
  "manifest_version": 3,
  "name": "Carval Auto采集器",
  "version": "1.6",
  "description": "阿里国际站汽车配件商品采集插件",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["*://*.aliexpress.com/*", "https://api.github.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
