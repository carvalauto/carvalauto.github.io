{
  "manifest_version": 3,
  "name": "Carval Auto Product Collector v22",
  "version": "22.0",
  "description": "采集阿里巴巴产品信息并推送到GitHub - v22版本（精准采集主图区域，排除缩略图）",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://www.alibaba.com/*",
    "https://*.alibaba.com/*",
    "https://*.aliexpress.com/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.alibaba.com/product-detail/*",
        "https://*.alibaba.com/product-detail/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

